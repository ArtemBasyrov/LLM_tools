# Environment Variables
# Copy this file to .env and adjust values for your setup.
# .env is gitignored and never committed.

# Ollama model to use (must be pulled locally via `ollama pull <model>`)
OLLAMA_MODEL=qwen3.5:35b

# Ollama server URL (change if running Ollama on a remote host or non-default port)
OLLAMA_HOST=http://localhost:11434

# (Optional) Custom directory for the semantic memory database
# Defaults to ~/.llm_memory/ if not set
# LLM_MEMORY_DIR=~/.llm_memory

# --- Agentic mode (planning / verification / critic) ------------------------
# Master switch — wrap each turn in the orchestrator state machine.
AGENTIC_MODE=true

# Block a final answer while an active plan still has unverified steps.
ENFORCE_PLANNING=true

# How many critic revise rounds to run on each final response (0 disables).
CRITIC_MAX_ROUNDS=2

# (Optional) Where plan JSON lives. Defaults to ~/.llm_plans/
# LLM_PLAN_DIR=~/.llm_plans

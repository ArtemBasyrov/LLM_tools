# Environment Variables
# Copy this file to .env and adjust values for your setup.
# .env is gitignored and never committed.

# Ollama model to use (must be pulled locally via `ollama pull <model>`)
OLLAMA_MODEL=qwen3.5:35b

# Ollama server URL (only used when LLM_BACKEND=ollama)
OLLAMA_HOST=http://localhost:11434

# Inference backend: llama_server (default, ik_llama.cpp + speculative decoding)
# or ollama (fallback). llama_server requires ./run_llama_server.sh running.
LLM_BACKEND=llama_server
LLAMA_SERVER_URL=http://127.0.0.1:8081

# --- llama-server (read by run_llama_server.sh) -----------------------------
# Speculative-decoding strategy with no draft model.
#   ""           — no speculation (baseline)
#   default      — --spec-default preset: ngram-mod n=24, draft 48..64 (PR #19164)
#                  ~3× tok/s on warm cache (repeated prompts / agentic loops);
#                  near-zero overhead cold. Recommended.
#   ngram-mod | ngram-cache | ngram-simple | ngram-map-k | ngram-map-k4v
#                — passed through as --spec-type <value>
SPEC=default

# (Optional) Override the runtime context length and port.
# CTX=32768
# PORT=8081

# (Optional) Custom directory for the semantic memory database
# Defaults to ~/.llm_memory/ if not set
# LLM_MEMORY_DIR=~/.llm_memory

# --- Web search (AgentSearch) ----------------------------------------------
# Self-hosted multi-engine search. Run via `docker compose up -d` from a clone
# of https://github.com/brcrusoe72/agent-search.
AGENT_SEARCH_URL=http://localhost:3939
# Optional bearer token (set if AGENT_SEARCH_TOKEN is configured on the server).
# AGENT_SEARCH_TOKEN=
# Where the agent-search repo is cloned. run_llama_server.sh will `docker compose
# up -d` here on launch and `stop` on exit. Set AGENT_SEARCH_AUTOSTART=0 to disable.
AGENT_SEARCH_DIR=$HOME/agent-search
# AGENT_SEARCH_AUTOSTART=1

# --- Agentic mode (planning / verification / critic) ------------------------
# Master switch — wrap each turn in the orchestrator state machine.
AGENTIC_MODE=true

# Block a final answer while an active plan still has unverified steps.
ENFORCE_PLANNING=true

# How many critic revise rounds to run on each final response (0 disables).
CRITIC_MAX_ROUNDS=2

# (Optional) Where plan JSON lives. Defaults to ~/.llm_plans/
# LLM_PLAN_DIR=~/.llm_plans
